{
  "name": "animation-factory",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "React 開発者向けの UI アニメーションカタログ。.animation.md として取得して AI に渡せる。MCP / CLI / web の 3 経路でアクセス可能。",
  "homepage": "https://animation-factory-five.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daichi8922028/animation-factory.git"
  },
  "bugs": {
    "url": "https://github.com/Daichi8922028/animation-factory/issues"
  },
  "scripts": {
    "predev": "npm run build:index",
    "dev": "next dev",
    "prebuild": "npm run build:index",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ignore-pattern '.vercel/**'",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "verify": "npm run lint && npm run check:content && npm run test:e2e",
    "check:content": "tsx scripts/check-content.ts",
    "build:index": "tsx scripts/build-index.ts",
    "build:thumbs": "tsx scripts/build-thumbs.ts",
    "build:screenshots": "tsx scripts/screenshot.ts"
  },
  "dependencies": {
    "@rive-app/react-canvas": "^4.28.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lottie-react": "^2.4.1",
    "marked": "^18.0.4",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
